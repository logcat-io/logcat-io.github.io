---
// giscus 설정 (전부 공개값 — 시크릿 아님). GitHub Discussions 가 백엔드, 내 DB·서버 0.
const repo = 'logcat-io/logcat-io.github.io';
const repoId = 'R_kgDOTAvntw';
const category = 'Announcements';
const categoryId = 'DIC_kwDOTAvnt84C_l1R';
---

{
  repo && (
    <section class="giscus-shell" aria-label="Comments">
      <script
        src="https://giscus.app/client.js"
        data-repo={repo}
        data-repo-id={repoId}
        data-category={category}
        data-category-id={categoryId}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="light"
        data-lang="ko"
        crossorigin="anonymous"
        async
      />
    </section>
  )
}

<style>
  .giscus-shell {
    max-width: 720px;
    margin: 0 auto;
    padding: 8px var(--gutter) 64px;
    border-top: 1px solid var(--hair);
  }
</style>
