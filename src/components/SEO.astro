---
export interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  /** 'website' (기본) | 'article' */
  ogType?: 'website' | 'article';
  /** og:type=article 일 때 글 메타(발행/수정 시각, 태그) */
  article?: ArticleMeta;
  /** 홈에서 WebSite+Blog 구조화 데이터를 추가로 내보낼지 */
  isHome?: boolean;
}

const siteTitle = 'LogCat';
const siteDescription =
  '소심한 엔지니어의 개발기록 — 백엔드부터 사이드 프로젝트, 바이브코딩까지 개발하며 남기는 LogCat 의 로그.';
const authorName = 'LogCat';

const {
  title,
  description,
  canonical,
  image,
  ogType = 'website',
  article,
  isHome = false,
} = Astro.props;

const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const site = Astro.site ?? new URL('https://logcat-io.github.io');
const siteUrl = site.toString().replace(/\/$/, '');
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site).toString();
// 이미지 미지정 시 사이트 기본 OG(자동 생성)로 폴백 — 모든 페이지가 OG 카드를 갖게.
const ogImage = new URL(image ?? '/og/site.png', site).toString();

// ---- JSON-LD 구조화 데이터 (빌드시 정적 직렬화, 런타임 JS 없음) ----
const author = { '@type': 'Person', name: authorName, url: siteUrl };

const articleLd =
  ogType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        url: canonicalUrl,
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
        inLanguage: 'ko-KR',
        author,
        publisher: { '@type': 'Organization', name: siteTitle, url: siteUrl },
        ...(article?.publishedTime ? { datePublished: article.publishedTime } : {}),
        ...(article?.modifiedTime ?? article?.publishedTime
          ? { dateModified: article?.modifiedTime ?? article?.publishedTime }
          : {}),
        ...(article?.tags && article.tags.length ? { keywords: article.tags.join(', ') } : {}),
        ...(ogImage ? { image: ogImage } : {}),
      }
    : null;

const homeLd = isHome
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteTitle,
        url: siteUrl + '/',
        description: siteDescription,
        inLanguage: 'ko-KR',
      },
      {
        '@context': 'https://schema.org',
        '@type': 'Blog',
        name: siteTitle,
        url: siteUrl + '/',
        description: siteDescription,
        inLanguage: 'ko-KR',
        author,
        publisher: { '@type': 'Organization', name: siteTitle, url: siteUrl },
      },
    ]
  : null;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={authorName} />
<meta http-equiv="content-language" content="ko-KR" />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content="ko_KR" />
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- article 메타 -->
{ogType === 'article' && article?.publishedTime && (
  <meta property="article:published_time" content={article.publishedTime} />
)}
{ogType === 'article' && (article?.modifiedTime ?? article?.publishedTime) && (
  <meta
    property="article:modified_time"
    content={article?.modifiedTime ?? article?.publishedTime}
  />
)}
{ogType === 'article' &&
  article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- JSON-LD 구조화 데이터 -->
{articleLd && (
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
)}
{homeLd && (
  <script type="application/ld+json" set:html={JSON.stringify(homeLd)} />
)}
