---
import Base from '../layouts/Base.astro';
---

<Base title="Search" description="LogCat 글 전문 검색.">
  <section class="search-head">
    <p class="page-kicker">INDEX / SEARCH</p>
    <h1 class="search-title">SEARCH</h1>
    <p class="search-sub mono">제목·본문 전문 검색 — pagefind</p>
  </section>

  <section class="search-wrap">
    <div id="search"></div>
    <noscript>
      <p class="search-note mono">검색은 JavaScript가 필요합니다.</p>
    </noscript>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    function initLogcatSearch() {
      if (!window.PagefindUI) return;
      new window.PagefindUI({
        element: '#search',
        showImages: false,
        showSubResults: true,
        translations: {
          placeholder: '검색어를 입력하세요 (제목·본문)',
          zero_results: '"[SEARCH_TERM]" 검색 결과가 없습니다',
        },
      });
    }
    if (document.readyState !== 'loading') initLogcatSearch();
    else document.addEventListener('DOMContentLoaded', initLogcatSearch);
  </script>
</Base>

<!-- pagefind UI 흑백 테마 (전역 변수) -->
<style is:global>
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #0a0a0a;
    --pagefind-ui-text: #0a0a0a;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #0a0a0a;
    --pagefind-ui-tag: #f5f5f5;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: 'Pretendard', system-ui, sans-serif;
  }
</style>

<style>
  .search-head {
    padding: 56px var(--gutter) 40px;
    border-bottom: 1px solid var(--hair);
  }

  .search-title {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(40px, 8vw, 72px);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .search-sub {
    margin: 16px 0 0;
    color: var(--g-60);
    font-size: 12px;
    letter-spacing: 1px;
  }

  .search-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px var(--gutter) 72px;
  }

  .search-note {
    color: var(--g-45);
    font-size: 12px;
    letter-spacing: 1px;
  }
</style>
